# Copy to `.env.local` and fill in values (see README.md).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional fallback if you use Supabase publishable key naming only:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only (billing / admin paths as used in code)
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=

# Required when NODE_ENV=production — cron must send Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Optional LLM defaults (see src/lib/env.ts)
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
